generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Role {
  ADMIN
  MEMBER
}

enum GoalType {
  DAILY
  WEEKLY
  MONTHLY
  FOREVER
}

// Main models
model User {
  id String @id @default(uuid()) @db.Uuid
  email String @unique
  name String
  password String
  avatar String?
  bio String?
  memberships Membership[]
  activityLogs ActivityLog[]
  refreshTokens RefreshToken[]
  createdAt DateTime @default(now())

}

model Group {
  id String @id @default(uuid()) @db.Uuid
  name String
  description String?
  icon String?
  totalDistance Float @default(0)
  isPrivate Boolean @default(true)
  memberships Membership[]
  activityLogs ActivityLog[]
  goals Goal[]
  invites Invite[]
  createdAt DateTime @default(now())
}

// Auxiliary models
model Membership{
  id String @id @default(uuid()) @db.Uuid
  role Role @default(MEMBER)
  
  group Group @relation(fields: [groupId], references: [id])
  groupId String @db.Uuid

  user User @relation(fields: [userId], references: [id])
  userId String @db.Uuid

  @@unique([userId, groupId])
}

model ActivityLog {
  id String @id @default(uuid()) @db.Uuid
  distance Float
  duration Int?
  location String?
  activityType String?
  photo String?

  user User @relation(fields: [userId], references: [id])
  userId String @db.Uuid

  group Group @relation(fields: [groupId], references: [id])
  groupId String @db.Uuid

  createdAt DateTime @default(now())
}

model Goal {
  id String @id @default(uuid()) @db.Uuid
  targetDistance Float
  type GoalType
  startDate DateTime
  endDate DateTime?
  group Group @relation(fields: [groupId], references: [id])
  groupId String @db.Uuid
}

model Invite {
  id String @id @default(uuid()) @db.Uuid
  token String @unique
  group Group @relation(fields: [groupId], references: [id])
  groupId String @db.Uuid
  expiration DateTime?
  createdAt DateTime @default(now())
}

model RefreshToken {
  id String @id @default(uuid()) @db.Uuid
  token String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.Uuid

  expiresAt DateTime

  @@map("refresh_tokens")
}