generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id String @id @default(uuid()) @db.Uuid

  username String @unique
  name String
  password String

}

model Group {
  id Int @id @default(autoincrement()) @db.Integer
  
}